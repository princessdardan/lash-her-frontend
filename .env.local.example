# Lash Her - Local Development Configuration

# Sanity CMS
# Project ID: 3auncj84
# Production Dataset: production
# Staging Dataset: staging-2026-05-10
# API Version: 2026-03-24
NEXT_PUBLIC_SANITY_PROJECT_ID=3auncj84
NEXT_PUBLIC_SANITY_DATASET=staging-2026-05-10
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-24

# Sanity Write and Webhook Tokens
# SANITY_WRITE_TOKEN: Required for server-side content updates
# SANITY_FORM_TOKEN: Legacy/conditional only. Current live form/contact writes use private Postgres.
# SANITY_WEBHOOK_SECRET: Signed secret for /api/revalidate
SANITY_WRITE_TOKEN=your_sanity_write_token
SANITY_API_READ_TOKEN=your_sanity_api_read_token
# SANITY_FORM_TOKEN=your_sanity_form_token
SANITY_WEBHOOK_SECRET=your_sanity_webhook_secret

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXX
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Google Calendar Booking
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/booking/oauth/callback
BOOKING_ADMIN_SETUP_SECRET=generate_a_long_random_setup_secret

# Upstash Redis / KV
KV_REST_API_URL=https://your-upstash-instance.upstash.io
KV_REST_API_TOKEN=your_kv_rest_api_token

# Private Checkout Database (Neon/Drizzle)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
PRIVATE_DB_MIGRATION_TARGET=local
PRIVATE_DB_MIGRATION_HOST=host
# PRIVATE_DB_MIGRATION_CONFIRM=production

# Payment Gateway Runtime (Server-only)
# Default to live provider credentials. Use PAYMENT_GATEWAY_MODE=mock only for local/dev mock payment flows.
# Mock mode is rejected in production and must never be exposed with NEXT_PUBLIC_ variables.
# In mock mode, PAYMENT_MOCK_DEFAULT_SCENARIO selects the default local provider response.
# Dev-only request controls, valid only when PAYMENT_GATEWAY_MODE=mock:
# - Header: x-lash-payment-mock-scenario
# - Query: mockPaymentScenario
PAYMENT_GATEWAY_MODE=live
PAYMENT_MOCK_DEFAULT_SCENARIO=success

# Helcim Checkout for product and training checkout (Server-only)
# Product checkout and training checkout remain Helcim-backed in live mode and should not require Square env vars.
HELCIM_GENERAL_API_TOKEN=your_helcim_general_api_token
HELCIM_TRANSACTION_API_TOKEN=your_helcim_transaction_api_token
CHECKOUT_SECRET_ENCRYPTION_KEY=base64_encoded_32_byte_key

# Square Service Booking (Server-only)
# Use SERVICE_BOOKING_SQUARE_ENABLED=true only for service-booking environments that should use Square.
# Square is not the provider for product checkout or training checkout.
# Use SQUARE_ENVIRONMENT=sandbox for local and preview deployments.
# Use SQUARE_ENVIRONMENT=production for live production deployments.
# Keep all Square secrets server-only and never prefix them with NEXT_PUBLIC_.
# In Vercel, scope sandbox values to Development/Preview and production values to Production.
SERVICE_BOOKING_SQUARE_ENABLED=false
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_SERVICE_BOOKING_RETURN_URL=http://localhost:3000/api/booking/square/return
SQUARE_SERVICE_BOOKING_WEBHOOK_URL=https://yourdomain.com/api/webhooks/square
# Optional migration cutoff for the Helcim-to-Square service-booking transition.
# SERVICE_BOOKING_HELCIM_LEGACY_CUTOFF_AT=2026-06-30T00:00:00Z

# Helcim Webhook Verification
# Webhook delivery URL must not contain "helcim" (e.g., /api/webhooks/card-transactions)
HELCIM_WEBHOOK_VERIFIER_TOKEN=your_helcim_webhook_verifier_token
