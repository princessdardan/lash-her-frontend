# Local Development Configuration
NEXT_PUBLIC_STRAPI_URL="http://localhost:1337"
NEXT_PUBLIC_MOTION_PLUS_LICENSE_KEY=your_motion_plus_key_here

# Vercel Blob Storage (Required for landing page images)
# Get this token from: https://vercel.com/dashboard → Your Project → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXX"

# Motion.dev registry token (for downloading motion-plus and motion-studio packages)
# Get this from your motion.dev account dashboard
MOTION_DEV_TOKEN=your_motion_dev_registry_token_here

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-24

# Sanity Write Tokens
SANITY_WRITE_TOKEN=your_sanity_write_token
SANITY_FORM_TOKEN=your_sanity_form_token_editor_role

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXX
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
