# Lash Her - Local Development Configuration

# Sanity CMS
# Project ID: 3auncj84
# Production Dataset: production
# Staging Dataset: staging-2026-05-10
# API Version: 2026-03-24
NEXT_PUBLIC_SANITY_PROJECT_ID=3auncj84
NEXT_PUBLIC_SANITY_DATASET=staging-2026-05-10
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-24

# Sanity Write and Webhook Tokens
# SANITY_WRITE_TOKEN: Required for server-side content updates
# SANITY_FORM_TOKEN: Required for form submissions (Editor role)
# SANITY_WEBHOOK_SECRET: Signed secret for /api/revalidate
SANITY_WRITE_TOKEN=your_sanity_write_token
SANITY_FORM_TOKEN=your_sanity_form_token
SANITY_WEBHOOK_SECRET=your_sanity_webhook_secret

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXX
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Google Calendar Booking
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/booking/oauth/callback
BOOKING_ADMIN_SETUP_SECRET=generate_a_long_random_setup_secret

# Upstash Redis / KV
KV_REST_API_URL=https://your-upstash-instance.upstash.io
KV_REST_API_TOKEN=your_kv_rest_api_token

# Private Checkout Database (Neon/Drizzle)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Helcim Checkout (Server-only)
HELCIM_GENERAL_API_TOKEN=your_helcim_general_api_token
HELCIM_TRANSACTION_API_TOKEN=your_helcim_transaction_api_token
CHECKOUT_SECRET_ENCRYPTION_KEY=base64_encoded_32_byte_key

# Helcim Webhook Verification
# Webhook delivery URL must not contain "helcim" (e.g., /api/webhooks/card-transactions)
HELCIM_WEBHOOK_VERIFIER_TOKEN=your_helcim_webhook_verifier_token
