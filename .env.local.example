# Local Development Configuration
NEXT_PUBLIC_STRAPI_URL="http://localhost:1337"
NEXT_PUBLIC_MOTION_PLUS_LICENSE_KEY=your_motion_plus_key_here

# Vercel Blob Storage (Required for landing page images)
# Get this token from: https://vercel.com/dashboard → Your Project → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXX"

# Motion.dev registry token (for downloading motion-plus and motion-studio packages)
# Get this from your motion.dev account dashboard
MOTION_DEV_TOKEN=your_motion_dev_registry_token_here

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-24

# Sanity Write Tokens
SANITY_WRITE_TOKEN=your_sanity_write_token
SANITY_FORM_TOKEN=your_sanity_form_token_editor_role

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXX
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Google Calendar Booking
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/booking/oauth/callback
BOOKING_ADMIN_SETUP_SECRET=generate_a_long_random_setup_secret

# Upstash Redis (Vercel integration)
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_URL=https://your-upstash-instance.upstash.io
KV_URL=rediss://default:your_kv_rest_api_token@your-upstash-instance.upstash.io:6379
REDIS_URL=rediss://default:your_kv_rest_api_token@your-upstash-instance.upstash.io:6379

# Helcim Checkout (server-only)
HELCIM_GENERAL_API_TOKEN=your_helcim_general_api_token
HELCIM_TRANSACTION_API_TOKEN=your_helcim_transaction_api_token
CHECKOUT_SECRET_ENCRYPTION_KEY=base64_encoded_32_byte_key

# Required to receive Helcim webhooks
# Note: Webhook delivery URL must not contain "helcim" (e.g., /api/webhooks/card-transactions)
HELCIM_WEBHOOK_VERIFIER_TOKEN=your_helcim_webhook_verifier_token
